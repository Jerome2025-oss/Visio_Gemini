# Copier vers .env et renseigner les clés (ne pas committer .env)
GOOGLE_API_KEY=...
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.mammouth.ai/v1
OPENAI_MODEL=gpt-5.4-mini
CHART_VISION_MODEL=gemini-3.1-flash-lite-preview

# Binaires Playwright — évite re-téléchargement dans le cache sandbox Cursor
PLAYWRIGHT_BROWSERS_PATH=/root/.cache/ms-playwright
