# ════════════════════════════════════════════════════════════════════════
#  Visio_Gemini — template des variables d'environnement
#  Copier vers .env et renseigner les valeurs (le .env n'est JAMAIS commité).
# ════════════════════════════════════════════════════════════════════════

# ── API vision Mammouth (analyse des graphiques via Gemini) ──────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.mammouth.ai/v1
OPENAI_MODEL=gpt-5.4-mini
CHART_VISION_MODEL=gemini-3.1-flash-lite-preview

# ── Playwright (capture TradingView) ─────────────────────────────────────
PLAYWRIGHT_BROWSERS_PATH=/root/.cache/ms-playwright

# ── Telegram / Telethon (module auto_listener) ───────────────────────────
# api_id + api_hash : à créer sur https://my.telegram.org → "API development tools"
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Nom du fichier de session Telethon (stocké dans secrets/<nom>.session)
TELEGRAM_SESSION_NAME=visio_gemini
# Canal de Jérôme à écouter : id numérique (ex. -1001234567890) ou @username
TELEGRAM_CHANNEL_ID=-1001234567890

# ── API backtest bitunix (projet Detecte_Pump_Bitunix_P) ─────────────────
# Endpoint /api/backtest/simulate_one utilisé par la page Analyses automatiques
# pour simuler TP/SL/levier sur un FLASH noté par Ichimoku.
BITUNIX_API_URL=http://localhost:8002
